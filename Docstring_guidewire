import os
from dotenv import load_dotenv

load_dotenv(os.path.join(os.path.dirname(__file__), ".env"))

import sys
sys.path.insert(0, os.path.dirname(__file__))

from graph import graph
from langgraph.types import Command

from fastapi import FastAPI
from fastapi.middleware.cors import CORSMiddleware
from fastapi.responses import StreamingResponse
from pydantic import BaseModel
import uvicorn
import json

AGENT_PORT = int(os.getenv("AGENT_PORT", "8002"))

# ── SSE Streaming Helpers ─────────────────────────────────────────────────────

async def _stream_graph(input_data, thread_id: str):
    """Shared generator for both /chat and /continue_chat."""
    config = {"configurable": {"thread_id": thread_id}}
    try:
        async for event in graph.astream(input_data, config):
            for value in event.values():
                if "messages" in value:
                    msg = value["messages"][-1]
                    if hasattr(msg, "model_dump"):
                        data = {"message": msg.model_dump()}
                    elif hasattr(msg, "dict"):
                        data = {"message": msg.dict()}
                    else:
                        data = {"message": str(msg)}
                    yield f"data: {json.dumps(data)}\n\n"
                else:
                    # LangGraph interrupt — human assistance required
                    try:
                        interrupt_payload = {
                            "query":   value[0].value["query"],
                            "id":      value[0].id,
                            "session": thread_id,
                        }
                        yield f"data: {json.dumps({'interrupt': interrupt_payload})}\n\n"
                    except (IndexError, KeyError, TypeError):
                        yield f"data: {json.dumps({'interrupt': {'query': str(value), 'session': thread_id}})}\n\n"
    except Exception as exc:
        yield f"data: {json.dumps({'error': str(exc)})}\n\n"


async def stream(message: str, thread_id: str):
    input_data = {"messages": [{"role": "user", "content": message}]}
    async for chunk in _stream_graph(input_data, thread_id):
        yield chunk


async def continue_stream(message: str, thread_id: str):
    input_data = Command(resume={"messages": [{"role": "user", "content": message}]})
    async for chunk in _stream_graph(input_data, thread_id):
        yield chunk

# ── FastAPI App ───────────────────────────────────────────────────────────────

app = FastAPI(
    title="Jarvis Claims Agent",
    description="Autonomous AI claims adjuster powered by LangGraph + Claude.",
    version="1.0.0",
    docs_url="/docs",
)

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

# ── Request Schema ────────────────────────────────────────────────────────────

class ChatInput(BaseModel):
    query: str
    thread_id: str

# ── Routes ────────────────────────────────────────────────────────────────────

@app.post(
    "/chat",
    summary="Start or continue a claim session",
    description="Send a message to Jarvis. Returns a server-sent event stream. "
                "Each event is either `{message: {...}}` (agent output) or "
                "`{interrupt: {query, id, session}}` (human assistance required).",
)
async def chat(input: ChatInput):
    return StreamingResponse(
        stream(input.query, input.thread_id),
        media_type="text/event-stream",
    )


@app.post(
    "/continue_chat",
    summary="Resume after a human-assistance interrupt",
    description="Called after the agent emits an `interrupt` event. "
                "Pass the same `thread_id` and the human's response as `query`.",
)
async def continue_chat(input: ChatInput):
    return StreamingResponse(
        continue_stream(input.query, input.thread_id),
        media_type="text/event-stream",
    )


@app.get("/health", summary="Health check")
async def health():
    return {
        "status": "ok",
        "agent": "Jarvis Claims Agent",
        "port": AGENT_PORT,
    }

# ── Entry Point ───────────────────────────────────────────────────────────────

if __name__ == "__main__":
    uvicorn.run(app, host="0.0.0.0", port=AGENT_PORT)
