def search_policy(policy_number: str) -> dict:
    """
    Search for a policy in Guidewire PolicyCenter by policy number.

    Uses: POST /policy/v1/search/policies
    Body: {"data": {"attributes": {"policyNumber": "<policy_number>"}}}

    Returns:
        The full Guidewire JSON response on success.
        Raises requests.HTTPError (404 etc.) if not found.

    Caller should check:
        result["data"]              — list of matched policies
        result["data"][0]           — first match
        result["data"][0]["attributes"]["policyNumber"]
        result["data"][0]["attributes"]["account"]["accountNumber"]
        result["data"][0]["attributes"]["periods"][0]["status"]
        result["data"][0]["attributes"]["periods"][0]["lines"]
    """
    body = {
        "data": {
            "attributes": {
                "policyNumber": policy_number
            }
        }
    }
    return _pc_post("/policy/v1/search/policies", body)


