"""
Jarvis Claims Agent — Interactive CLI Client

Usage:
    python client.py
    Type 'exit' or 'quit' to end the session.
"""

import asyncio
import httpx
import uuid
import json
import os
from dotenv import load_dotenv

load_dotenv(os.path.join(os.path.dirname(__file__), ".env"))

AGENT_URL = os.getenv("AGENT_URL", "http://localhost:8002")

W = 70  # display width

# ── Colours ───────────────────────────────────────────────────────────────────
C = {
    "reset":    "\033[0m",
    "bold":     "\033[1m",
    "dim":      "\033[2m",
    "user":     "\033[94m",   # blue
    "ai":       "\033[92m",   # green
    "tool_call":"\033[95m",   # magenta
    "tool_ok":  "\033[96m",   # cyan
    "tool_err": "\033[91m",   # red
    "interrupt":"\033[93m",   # yellow
    "error":    "\033[91m",   # red
    "rule":     "\033[90m",   # dark grey
}

def rule(char="─"):
    print(f"{C['rule']}{char * W}{C['reset']}")

def header(label: str, colour: str):
    pad = W - len(label) - 4
    left = pad // 2
    right = pad - left
    print(f"{colour}{'─' * left}[ {label} ]{'─' * right}{C['reset']}")

def block(label: str, colour: str, body: str):
    header(label, colour)
    for line in body.strip().splitlines():
        print(f"  {colour}{line}{C['reset']}")
    rule()

# ── Content extractor ─────────────────────────────────────────────────────────

def extract_text(content) -> str:
    if isinstance(content, str):
        return content
    if isinstance(content, list):
        parts = []
        for item in content:
            if isinstance(item, dict):
                parts.append(item.get("text") or item.get("content") or json.dumps(item))
            else:
                parts.append(str(item))
        return "\n".join(p for p in parts if p)
    return str(content) if content else ""

# ── Stream Handler ────────────────────────────────────────────────────────────

async def stream_chat(query: str, thread_id: str, endpoint: str = "/chat"):
    payload  = {"query": query, "thread_id": thread_id}
    final_state = {"state": ""}

    async with httpx.AsyncClient(timeout=None) as client:
        async with client.stream("POST", f"{AGENT_URL}{endpoint}", json=payload) as response:
            async for line in response.aiter_lines():
                if not line.startswith("data: "):
                    continue
                raw = line.removeprefix("data: ").strip()
                if not raw:
                    continue
                try:
                    parsed = json.loads(raw)
                except json.JSONDecodeError:
                    continue

                # ── Stream-level error ────────────────────────────────────────
                if "error" in parsed:
                    block("STREAM ERROR", C["error"], parsed["error"])
                    yield parsed

                # ── Agent message ─────────────────────────────────────────────
                elif "message" in parsed:
                    msg      = parsed["message"]
                    msg_type = msg.get("type", "") if isinstance(msg, dict) else ""
                    content  = msg.get("content", "") if isinstance(msg, dict) else str(msg)

                    if msg_type == "ai":
                        tool_calls = msg.get("tool_calls") or []

                        # Tool-call invocations
                        for tc in tool_calls:
                            name = tc.get("name", "?")
                            args = tc.get("args") or tc.get("input") or {}
                            body = json.dumps(args, indent=2, ensure_ascii=False)
                            block(f"TOOL CALL → {name}", C["tool_call"], body)

                        # Plain AI text (no tool call)
                        if not tool_calls:
                            text = extract_text(content)
                            if text:
                                block("JARVIS", C["ai"], text)

                    elif msg_type == "tool":
                        name = msg.get("name", "tool")
                        text = extract_text(content)
                        is_err = "error" in text.lower() or "failed" in text.lower()
                        colour = C["tool_err"] if is_err else C["tool_ok"]
                        label  = f"TOOL ERROR ← {name}" if is_err else f"TOOL RESULT ← {name}"
                        block(label, colour, text[:600] + ("…" if len(text) > 600 else ""))

                    elif msg_type == "human":
                        text = extract_text(content)
                        if text:
                            block("YOU", C["user"], text)

                    yield parsed

                # ── Human-in-the-loop interrupt ───────────────────────────────
                elif "interrupt" in parsed:
                    data = parsed["interrupt"]
                    query_text = data.get("query", str(data))
                    block("JARVIS ASKS — Human Assistance Required", C["interrupt"], query_text)
                    final_state = {"state": "interrupt", "content": parsed}
                    yield parsed

    yield final_state

# ── Main Loop ─────────────────────────────────────────────────────────────────

async def main():
    session_id = str(uuid.uuid4())
    state = {"state": ""}

    print()
    print(f"{C['ai']}{C['bold']}{'═' * W}{C['reset']}")
    print(f"{C['ai']}{C['bold']}{'  Jarvis Claims Agent':^{W}}{C['reset']}")
    print(f"{C['rule']}{'  Session: ' + session_id:^{W}}{C['reset']}")
    print(f"{C['rule']}{'  Type exit to quit':^{W}}{C['reset']}")
    print(f"{C['ai']}{C['bold']}{'═' * W}{C['reset']}")
    print()

    while True:
        try:
            user_input = input(f"{C['user']}{C['bold']}You:{C['reset']} ").strip()
        except (EOFError, KeyboardInterrupt):
            print("\nSession ended.")
            break

        if user_input.lower() in ("exit", "quit", "q"):
            print("Session ended.")
            break

        if not user_input:
            continue

        # Echo the user message in the same block style
        rule("─")
        header("YOU", C["user"])
        print(f"  {C['user']}{user_input}{C['reset']}")
        rule("─")
        print()

        endpoint  = "/continue_chat" if state.get("state") == "interrupt" else "/chat"
        new_state = {"state": ""}

        async for resp in stream_chat(user_input, session_id, endpoint):
            if isinstance(resp, dict):
                if resp.get("state") == "interrupt":
                    new_state = resp
                elif resp.get("state") == "":
                    new_state = {"state": ""}

        state = new_state
        print()


if __name__ == "__main__":
    asyncio.run(main())



