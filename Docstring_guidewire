    conn = get_db_connection()
    try:
        cur = conn.cursor()

        validation_id = f"COV-{req.claim_id}-{int(datetime.utcnow().timestamp())}"

        # Save to intake_validation_result_output (coverage_status + result fields)
        cur.execute(
            """
            INSERT INTO intake_validation_result_output (
                validation_id, claim_id, completeness_score,
                coverage_status, fraud_risk, result, created_at
            ) VALUES (%s, %s, %s, %s, %s, %s, NOW())
            RETURNING *
            """,
            (
                validation_id,
                req.claim_id,
                100,  # completeness not relevant here
                req.coverage_status,
                "Low",
                req.coverage_decision,
            ),
        )
        verification_row = dict(cur.fetchone())

        # Upsert policy_details with Guidewire data
        cur.execute(
            "SELECT id FROM policy_details WHERE policy_id = %s LIMIT 1",
            (req.policy_number,),
        )
        existing = cur.fetchone()
        if existing:
            cur.execute(
                """
                UPDATE policy_details
                SET status = %s, coverage_type = %s, deductible = %s, "limit" = %s
                WHERE policy_id = %s
                RETURNING *
                """,
                (
                    "Active" if req.coverage_status == "Confirmed" else "Under Review",
                    req.coverage_type_matched,
                    req.deductible,
                    req.coverage_limit,
                    req.policy_number,
                ),
            )
        else:
            cur.execute(
                """
                INSERT INTO policy_details (policy_id, status, coverage_type, deductible, "limit")
                VALUES (%s, %s, %s, %s, %s)
                RETURNING *
                """,
                (
                    req.policy_number,
                    "Active" if req.coverage_status == "Confirmed" else "Under Review",
                    req.coverage_type_matched,
                    req.deductible,
                    req.coverage_limit,
                ),
            )
        policy_row = dict(cur.fetchone())

        conn.commit()
        return {
            "verification_record": verification_row,
            "policy_details":      policy_row,
            "validation_id":       validation_id,
        }
    except Exception:
        conn.rollback()
        raise
    finally:
        conn.close()


