# ── Guidewire: Policy Search ──────────────────────────────────────────────────

def gw_search_policy(policy_number: str) -> dict:
    """
    Searches Guidewire PolicyCenter for the given policy number.

    Returns a normalised dict with:
      found            : bool
      policy           : flat policy dict (or None)
      error            : error message if not found / API error
      raw_gw_response  : the full Guidewire JSON (for downstream tools)
    """
    try:
        raw = guidewire_client.search_policy(policy_number)
        parsed = guidewire_client.parse_policy_from_search(raw)

        if not parsed:
            return {
                "found": False,
                "policy": None,
                "error": f"No policy found in Guidewire for policy number '{policy_number}'.",
                "raw_gw_response": raw,
            }

        return {
            "found": True,
            "policy": parsed,
            "error": None,
            "raw_gw_response": raw,
        }

    except Exception as exc:
        status_code = getattr(getattr(exc, "response", None), "status_code", None)
        if status_code == 404:
            return {
                "found": False,
                "policy": None,
                "error": f"Policy '{policy_number}' does not exist in Guidewire (HTTP 404). "
                         "Verify the policy number and retry.",
                "raw_gw_response": {},
            }
        log.exception("Guidewire policy search failed for %s", policy_number)
        return {
            "found": False,
            "policy": None,
            "error": f"Guidewire API error: {str(exc)}",
            "raw_gw_response": {},
        }


# ── Guidewire: Policy Coverages ───────────────────────────────────────────────

def gw_get_policy_coverages(policy_number: str) -> dict:
    """
    Fetches full coverage details for a policy from Guidewire.
    First searches by policy number, then fetches the policy detail record.
    """
    search_result = gw_search_policy(policy_number)
    if not search_result["found"]:
        return search_result

    gw_policy_id = search_result["policy"]["gw_policy_id"]
    try:
        detail = guidewire_client.get_policy_coverages(gw_policy_id)
        return {
            "found": True,
            "policy_id": gw_policy_id,
            "coverage_detail": detail,
            "error": None,
        }
    except Exception as exc:
        log.exception("Guidewire get_policy_coverages failed for %s", gw_policy_id)
        return {
            "found": False,
            "policy_id": gw_policy_id,
            "coverage_detail": None,
            "error": str(exc),
        }


# ── Coverage Verification (LLM) ───────────────────────────────────────────────

_COVERAGE_VERIFICATION_PROMPT = """
You are an expert insurance coverage analyst. Your job is to determine whether a
reported loss is covered under the given policy, based on the information available.

You will receive:
1. The reported loss type and description from the policyholder
2. The policy information retrieved from Guidewire (coverage types, status, dates)

Your task is to:
a) Confirm whether the policy is ACTIVE on the date of loss
b) Determine if the reported loss type falls within the policy's coverage
c) Identify any likely exclusions that may apply
d) Provide a clear coverage decision with reasoning

Return ONLY valid JSON in this exact format:
{
  "coverage_decision": "Covered" | "Not Covered" | "Conditionally Covered",
  "coverage_status":   "Confirmed" | "Excluded" | "Partial" | "Pending Review",
  "policy_active":     true | false,
  "coverage_type_matched": "<the specific coverage clause that applies, or null>",
  "deductible_applicable": <integer or null>,
  "limit_applicable": <integer or null>,
  "exclusion_reason": "<reason if not covered, or null>",
  "confidence": <0-100>,
  "reasoning": "<1-3 sentence explanation of your decision>",
  "missing_info": ["<any information needed to finalise determination>"]
}
"""


def verify_coverage_against_loss(req: VerifyCoverageRequest) -> dict:
    """
    Uses Azure OpenAI to compare the reported loss type and description
    against the policy coverage terms retrieved from Guidewire.

    If req.policy_data is not provided, automatically calls Guidewire first.
    """
    # Step 1: Get policy data if not supplied
    if req.policy_data:
        policy_info = req.policy_data
        gw_found = True
    else:
        search_result = gw_search_policy(req.policy_number)
        if not search_result["found"]:
            return {
                "coverage_decision": "Not Covered",
                "coverage_status": "Pending Review",
                "policy_active": False,
                "error": search_result["error"],
                "confidence": 0,
            }
        policy_info = search_result["policy"]
        gw_found = True

    # Step 2: Call Azure OpenAI to reason over coverage
    client = _get_openai_client()

    user_content = f"""
REPORTED LOSS:
  Claim ID    : {req.claim_id}
  Loss Type   : {req.reported_loss_type}
  Description : {req.loss_description or 'Not provided'}
  Loss Date   : {req.loss_date or 'Not provided'}

POLICY FROM GUIDEWIRE:
  Policy Number  : {req.policy_number}
  Status         : {policy_info.get('status', 'Unknown')}
  Effective Date : {policy_info.get('effective_date', 'Unknown')}
  Expiry Date    : {policy_info.get('expiration_date', 'Unknown')}
  Coverage Types : {policy_info.get('coverage_types', [])}
  Insured Name   : {policy_info.get('insured_name', 'Unknown')}
"""

    response = client.chat.completions.create(
        model=AZURE_OPENAI_CHAT_DEPLOYMENT,
        messages=[
            {"role": "system", "content": _COVERAGE_VERIFICATION_PROMPT},
            {"role": "user",   "content": user_content},
        ],
        temperature=0.0,
        response_format={"type": "json_object"},
    )

    content = response.choices[0].message.content
    try:
        result = json.loads(content)
        result["policy_number"] = req.policy_number
        result["claim_id"] = req.claim_id
        return result
    except json.JSONDecodeError:
        log.error("LLM returned non-JSON for coverage verification: %s", content)
        return {
            "coverage_decision": "Pending Review",
            "coverage_status": "Pending Review",
            "error": "Failed to parse LLM response",
            "raw": content,
        }


