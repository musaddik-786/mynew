def split_blob_url(blob_url: str) -> Tuple[str, str, str]:
    parsed = urlparse(blob_url)
    account_url = f"{parsed.scheme}://{parsed.netloc}"
    parts = parsed.path.lstrip("/").split("/", 1)
    container = parts[0]
    blob_name = unquote(parts[1]) if len(parts) > 1 else ""
    return account_url, container, blob_name


def resolve_blob(blob_url: Optional[str], blob_name: Optional[str]):
    if blob_url:
        return split_blob_url(blob_url)

    if not (AZURE_BLOB_ACCOUNT_URL and AZURE_BLOB_CONTAINER and blob_name):
        raise ValueError("Provide blob_url OR blob_name with AZURE_BLOB_* env vars")

    return AZURE_BLOB_ACCOUNT_URL, AZURE_BLOB_CONTAINER, blob_name


