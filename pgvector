def escape_non_template_vars(template: str, allowed_vars: set[str]) -> str:
    """
    Make the prompt LangChain-safe by:
    1. Escaping ALL braces
    2. Re-enabling only allowed template variables
    """

    # Step 1: Escape EVERYTHING
    escaped = template.replace("{", "{{").replace("}", "}}")

    # Step 2: Restore allowed variables
    for var in allowed_vars:
        escaped = escaped.replace(
            "{{" + var + "}}",
            "{" + var + "}"
        )

    return escaped
