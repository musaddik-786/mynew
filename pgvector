#### code for skipping duplicates in ingestion
def _ingest_with_conn(conn, reference_id: str, container: str, blob_name: str, doc_id: str, chunks, embeddings):
    """Core ingestion logic — called with an already-open connection."""
    attachment_id = blob_name
    ensure_pgvector_table(conn)

    rows_to_insert = []
    for (page, idx, chunk_content), emb in zip(chunks, embeddings):
        content_hash = compute_content_hash(chunk_content)
        if chunk_exists(conn, reference_id, content_hash):
            logger.info(
                "Duplicate chunk skipped",
                extra={"reference_id": reference_id, "chunk_index": idx}
            )
            continue
        rows_to_insert.append(
            (
                doc_id,
                f"{container}/{blob_name}",
                page,
                idx,
                chunk_content,
                content_hash,
                vec(emb),
                json.dumps({"chunk": idx}),
                reference_id,
                attachment_id,
            )
        )

    if not rows_to_insert:
        logger.warning("No new chunks to ingest", extra={"reference_id": reference_id})
        return "no_new_chunks"

    with conn.cursor() as cur:
        execute_values(
            cur,
            f"""
            INSERT INTO {DB_SCHEMA}.{DB_TABLE}
            (
                doc_id, source, page, chunk_index,
                content, content_hash, embedding,
                metadata, mail_ref_id, attachment_id
            )
            VALUES %s
            ON CONFLICT DO NOTHING
            """,
            rows_to_insert,
        )
    conn.commit()
    return rows_to_insert


def ingest(reference_id: str, account_url: str, container: str, blob_name: str):
    logger.info(
        "Starting vector ingestion",
        extra={"reference_id": reference_id, "blob_name": blob_name}
    )

    text = read_txt_from_blob(account_url, container, blob_name)
    chunks = chunk_text(text)
    embeddings = embed_texts([c[2] for c in chunks])
    doc_id = hashlib.sha1(f"{container}/{blob_name}".encode()).hexdigest()

    _RETRYABLE = (psycopg2.OperationalError, psycopg2.InterfaceError)
    max_attempts = 3

    for attempt in range(1, max_attempts + 1):
        try:
            conn = get_chunk_conn()
            try:
                rows_to_insert = _ingest_with_conn(conn, reference_id, container, blob_name, doc_id, chunks, embeddings)
            finally:
                try:
                    conn.close()
                except Exception:
                    pass
            break  # success
        except _RETRYABLE as e:
            logger.warning(
                "DB connection error on attempt %d/%d, retrying with fresh connection: %s",
                attempt, max_attempts, e,
                extra={"reference_id": reference_id}
            )
            if attempt == max_attempts:
                logger.error(
                    "Ingestion failed after %d attempts due to connection errors",
                    max_attempts,
                    extra={"reference_id": reference_id}
                )
                raise

    if rows_to_insert == "no_new_chunks":
        return "no_new_chunks"

    logger.info(
        "Vector ingestion successful",
        extra={"reference_id": reference_id, "chunks_inserted": len(rows_to_insert)}
    )
    return "ingested"

