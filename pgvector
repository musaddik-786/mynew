TEMPLATED_DOCUMENT_TYPES = {
    "accord",
    "accord_certificate",
    "accord_form"
}


def is_templated_doc(document_type: str) -> int:
    """
    Returns 1 if document is templated, else 0
    """
    if not document_type:
        return 0
    return 1 if document_type.lower() in TEMPLATED_DOCUMENT_TYPES else 0


def get_connection():
    if not DATABASE_URL:
        raise RuntimeError("DATABASE_URL not set in .env")
    return psycopg2.connect(DATABASE_URL)


def insert_attachment_info(
    *,
    reference_id: str,
    blob_url: str,
    document_type: str
):
    """
    Inserts metadata into attachment_info table
    """

    is_templated = is_templated_doc(document_type)

    with get_connection() as conn:
        with conn.cursor() as cur:
            cur.execute(
                f"""
                INSERT INTO {ATTACHMENT_INFO_SCHEMA}.{ATTACHMENT_INFO_TABLE} (
                    submission_id,
                    attachment_blob_url,
                    document_classification,
                    is_templated
                )
                VALUES (%s, %s, %s, %s)
                ON CONFLICT DO NOTHING
                """,
                (
                    reference_id,
                    blob_url,
                    document_type,
                    is_templated
                )
            )
        conn.commit()




