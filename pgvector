def upload_json_to_blob(
    *,
    container_name: str,
    file_name: str,
    data: dict
) -> str:
    """
    Upload JSON data to Azure Blob Storage and return the blob URL.

    Requires:
      - AZURE_STORAGE_CONNECTION_STRING
      - OUTPUT_BLOB_CONTAINER (passed in as container_name)

    Auto-creates container if it does not exist.
    """

    from azure.storage.blob import BlobServiceClient
    from azure.core.exceptions import ResourceExistsError

    connection_string = os.getenv("AZURE_STORAGE_CONNECTION_STRING_PGVECTOR")
    if not connection_string:
        raise RuntimeError(
            "AZURE_STORAGE_CONNECTION_STRING is not set in .env"
        )

    if not container_name:
        raise RuntimeError(
            "OUTPUT_BLOB_CONTAINER is not set or empty"
        )

    # Initialize client
    blob_service_client = BlobServiceClient.from_connection_string(
        connection_string
    )

    container_client = blob_service_client.get_container_client(
        container_name
    )

    # Create container if missing
    try:
        container_client.create_container()
        logger.info(f"☁️ Created blob container: {container_name}")
    except ResourceExistsError:
        pass  # Container already exists

    blob_client = container_client.get_blob_client(file_name)

    payload = json.dumps(
        data,
        indent=2,
        ensure_ascii=False
    ).encode("utf-8")

    # Upload JSON
    blob_client.upload_blob(
        payload,
        overwrite=True,
        content_type="application/json"
    )

    logger.info(f"☁️ Uploaded output JSON to blob: {blob_client.url}")

    return blob_client.url



async def invoke_llm_with_retry(
    chain,
    payload: Dict[str, Any],
    *,
    max_retries: int = 5,
    base_delay: float = 1.0,
):
    logger.info("🧠 LLM CALL MADE")
    """
    Invoke LLM with retry + exponential backoff
    Retries ONLY on Azure OpenAI rate limiting (429)
    """
    for attempt in range(1, max_retries + 1):
        try:
            async with llm_semaphore:
                return await asyncio.to_thread(
                    chain.invoke,
                    payload
                )

        except Exception as e:
            msg = str(e).lower()

            if "429" in msg or "too_many_requests" in msg:
                if attempt == max_retries:
                    raise

                backoff = base_delay * (2 ** (attempt - 1))
                backoff += random.uniform(0, 0.5)

                logger.warning(
                    f"🚦 OpenAI throttled (attempt {attempt}/{max_retries}), "
                    f"retrying in {backoff:.2f}s"
                )
                await asyncio.sleep(backoff)
            else:
                # Non-rate-limit errors should fail fast
                raise

