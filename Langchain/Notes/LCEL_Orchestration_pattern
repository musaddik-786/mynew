# orchestration_demo.py

import os

from dotenv import load_dotenv

from langchain_core.runnables import (

    RunnableLambda,

    RunnableBranch,

    RunnablePassthrough

)

from langchain_core.prompts import ChatPromptTemplate

from langchain_openai import ChatOpenAI

from langchain_core.output_parsers import StrOutputParser

load_dotenv()


# -------------------------------------

# Step 1: Clean input

# -------------------------------------

def clean_input(text: str) -> str:

    return " ".join(text.strip().split())

clean_step = RunnableLambda(clean_input)


# -------------------------------------

# Step 2: Extract age using LLM

# -------------------------------------

extract_prompt = ChatPromptTemplate.from_template("""

Extract the age from the following sentence:

{text}

Just return a number.

""")

model = ChatOpenAI(model="gpt-4o-mini", temperature=0)

extract_age = extract_prompt | model | StrOutputParser()


# -------------------------------------

# Step 3: Convert age string to integer

# -------------------------------------

def convert_age(age_str: str):

    try:

        return int(age_str)

    except:

        return None

convert_step = RunnableLambda(convert_age)


# -------------------------------------

# Step 4: Conditional logic (Underwriting rule)

# -------------------------------------

def age_check(age: int):

    if age is None:

        return "invalid"

    return "minor" if age < 18 else "adult"


# Branching:

# minor → rejection

# adult → approval

branch = RunnableBranch(

    (lambda x: x == "minor", RunnableLambda(lambda _: "REJECTED: Underage")),

    (lambda x: x == "adult", RunnableLambda(lambda _: "APPROVED")),

    RunnableLambda(lambda _: "INVALID AGE")

)


# -------------------------------------

# BUILD WORKFLOW

# -------------------------------------

workflow = (

    clean_step

    | extract_age

    | convert_step

    | age_check

    | branch

)


# -------------------------------------

# RUN

# -------------------------------------

def main():

    print("Orchestration demo ready. Type 'exit' to quit.\n")

    while True:

        text = input("Enter user input: ").strip()

        if text.lower() in ("exit", "quit"):

            break

        result = workflow.invoke(text)

        print("\nResult:")

        print(result)

        print("-" * 50)


if __name__ == "__main__":

    main()


