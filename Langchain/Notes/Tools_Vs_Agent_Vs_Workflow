# tool_vs_agent_demo.py

import os

from dotenv import load_dotenv

from langchain_openai import ChatOpenAI

from langchain_core.tools import tool

from langchain_core.prompts import ChatPromptTemplate

from langchain_core.output_parsers import StrOutputParser

from langchain.agents import create_openai_functions_agent, AgentExecutor

load_dotenv()

llm = ChatOpenAI(model="gpt-4o-mini", temperature=0)


# ------------------------------------------------

# SHARED TOOLS

# ------------------------------------------------

@tool

def add(a: int, b: int) -> int:

    """Add two integers."""

    return a + b

@tool

def multiply(a: int, b: int) -> int:

    """Multiply two integers."""

    return a * b

tools = [add, multiply]


⸻

1️⃣ DEMO A – Plain Tool Calling (one-shot)

Here we only use bind_tools.

No agent, no loop.

# ------------------------------------------------

# DEMO A: Plain tool calling (no agent, no loop)

# ------------------------------------------------

def demo_tool_calling():

    prompt = ChatPromptTemplate.from_template("""

You are a math assistant.

You have these tools:

- add(a, b)

- multiply(a, b)

Use them if needed to answer the question.

Question: {question}

""")

    llm_with_tools = llm.bind_tools(tools)

    chain = prompt | llm_with_tools | StrOutputParser()

    print("\n=== DEMO A: Plain Tool Calling (ONE-SHOT) ===\n")

    question = "First add 2 and 3, then multiply the result by 4."

    print("User:", question)

    # One single call

    answer = chain.invoke({"question": question})

    print("\nLLM Final Output (one call):")

    print(answer)

    print("\n[Note] This was a single LLM call. Any math steps or 'tool ideas'\n"

          "all happened inside that ONE call. No loop, no multi-step plan outside.")

What’s happening here?

	•	We call the model once with both tools bound.

	•	Inside that call, the LLM may:

	•	mentally do 2+3=5, 5*4=20,

	•	or decide to call one tool, or

	•	output a final answer directly.

	•	There is no external loop that:

	•	runs tool → sends real result back → calls LLM again.

So even though there are two tools, this is still a single round.

