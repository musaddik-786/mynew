# memory_demo.py

import os

from dotenv import load_dotenv

from langchain_openai import ChatOpenAI

from langchain_core.prompts import ChatPromptTemplate

from langchain.memory import ConversationBufferMemory

from langchain.chains import LLMChain

load_dotenv()


# ------------------------------------------------

# 1. Create Memory

# ------------------------------------------------

memory = ConversationBufferMemory(

    memory_key="chat_history",      # name used inside prompt

    return_messages=True            # store messages as objects, not plain text

)


# ------------------------------------------------

# 2. Prompt using memory

# ------------------------------------------------

prompt = ChatPromptTemplate.from_messages([

    ("system", "You are a helpful assistant."),

    ("messages", "{chat_history}"),     # <-- memory goes here

    ("human", "{user_input}")

])


# ------------------------------------------------

# 3. Create LLM

# ------------------------------------------------

llm = ChatOpenAI(

    model="gpt-4o-mini",

    temperature=0

)


# ------------------------------------------------

# 4. Chain that includes memory

# ------------------------------------------------

chain = LLMChain(

    llm=llm,

    prompt=prompt,

    memory=memory,

    verbose=True

)


# ------------------------------------------------

# 5. Run conversation

# ------------------------------------------------

def main():

    print("Memory-enabled chat. Type 'exit' to quit.\n")

    while True:

        user = input("You: ").strip()

        if user.lower() in ("exit", "quit"):

            break

        response = chain.invoke({"user_input": user})

        print("AI:", response["text"])

        print("-" * 40)


if __name__ == "__main__":

    main()


⸻

⭐ Now let’s understand what’s happening step-by-step:

🔵 Step 1: Memory creation

memory = ConversationBufferMemory(...)

This stores messages like:

Human: My name is Musaddik.

AI: Nice to meet you.

Human: What is my name?


⸻

🔵 Step 2: Prompt that includes memory

("messages", "{chat_history}")

This means:

	•	Before sending prompt to LLM,

	•	LangChain will automatically insert past messages.

Example prompt sent to LLM:

System: You are a helpful assistant.

Human: My name is Musaddik.

AI: Nice to meet you.

Human: What is my name?


⸻

🔵 Step 3: Chain with memory

chain = LLMChain(..., memory=memory)

This is the magic.

Every time you call:

chain.invoke({"user_input": "Tell me my name"})

Step 1: Memory feeds previous chat

Step 2: LLM gets history + new query

Step 3: LLM answers

Step 4: Memory saves the new pair

⸻

🧪 Try these messages:

User:

My name is Musaddik.

User:

I am 28 years old.

User:

What is my age?

AI will respond:

You are 28 years old.

User:

What is my name?

AI will respond:

Your name is Musaddik.

Because the memory kept everything.

