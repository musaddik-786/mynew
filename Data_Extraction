




import os
from urllib.parse import urlparse, unquote
from dotenv import load_dotenv

load_dotenv()

AZURE_STORAGE_CONNECTION_STRING = os.environ.get(
    "AZURE_STORAGE_CONNECTION_STRING", ""
)

GUIDEWIRE_BIND_AND_ISSUE_CONTAINER = os.environ.get(
    "GUIDEWIRE_BIND_AND_ISSUE_CONTAINER",
    "guidewire_bind_and_issue",
)


def _require_env() -> None:
    """
    Ensure required Azure Storage environment variables exist.
    """
    if not AZURE_STORAGE_CONNECTION_STRING:
        raise RuntimeError(
            "Missing AZURE_STORAGE_CONNECTION_STRING in environment/.env"
        )


def _parse_blob_url(url: str) -> tuple[str, str]:
    """
    Parse an Azure Blob URL and return:

        (container_name, blob_path)

    Example
    -------
    Input:
        https://account.blob.core.windows.net/guidewire-quote/
        19F64D19C34B9B1C_Quote_Report_20260715_081238_mail.json

    Returns:
        (
            "guidewire-quote",
            "19F64D19C34B9B1C_Quote_Report_20260715_081238_mail.json"
        )
    """

    parsed = urlparse(url)

    if not parsed.scheme.startswith("http"):
        raise ValueError("Invalid Azure Blob URL.")

    path = parsed.path.lstrip("/")

    if "/" not in path:
        raise ValueError(
            "Blob URL must contain both container and blob name."
        )

    container, blob_path = path.split("/", 1)

    return unquote(container), unquote(blob_path)


def build_bind_and_issue_blob_name(original_blob_name: str) -> str:
    """
    Build the Bind & Issue blob filename.

    Rule
    ----
    Replace only the token immediately after the reference ID with
    'bind_and_issue'.

    Example
    -------
    Input

        19F64D19C34B9B1C_Quote_Report_20260715_081238_mail.json

    Output

        19F64D19C34B9B1C_bind_and_issue_Report_20260715_081238_mail.json

    Another Example

        19F64D19C34B9B1C_Submission_Report_20260715.json

    Output

        19F64D19C34B9B1C_bind_and_issue_Report_20260715.json
    """

    parts = original_blob_name.split("_", 2)

    if len(parts) < 3:
        raise ValueError(
            "Unexpected blob filename format."
            " Expected REFID_<TYPE>_<remaining_filename>."
        )

    ref_id = parts[0]
    remaining = parts[2]

    return f"{ref_id}_bind_and_issue_{remaining}"


