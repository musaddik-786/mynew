def update_repair_vs_replacement_decision(
    claim_number: str,
    decision: str,
) -> dict:
    decision = decision.strip().capitalize()
    if decision not in ["Repair", "Replace"]:
        raise ValueError(
            "Decision must be either 'Repair' or 'Replace'."
        )
    conn = get_db_connection()
