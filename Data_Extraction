class State(TypedDict):
    messages: Annotated[list, add_messages]


def router(state: State):
    last = state["messages"][-1]
    if isinstance(last, AIMessage) and getattr(last, "tool_calls", None):
        return "tools"
    return "End"


_FALLBACK_PROMPT = """
You are the Policy Coverage Verification Agent (Policyholder, local-DB
version) for an insurance claims platform.

THIS AGENT IS A PLACEHOLDER PENDING FULL DESIGN.

Currently the only available tool is get_policy_details_stub, which reads
