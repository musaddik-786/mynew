def get_claim_id(claim_number: str) -> int:
   claim_id = get_claim_id(claim_number)
   conn = get_db_connection()
   try:
       cur = conn.cursor()
       cur.execute(
           """
           SELECT id
           FROM claims
           WHERE claim_number = %s
           """,
           (claim_number,),
       )
       row = row_to_dict(cur.fetchone())
