


from pydantic import BaseModel, Field


class BindIssueRequest(BaseModel):
    """
    Request model for the Guidewire Bind & Issue MCP.

    This model accepts the Job ID generated by the Guidewire Quote MCP
    along with the Quote MCP output blob URL.

    The output_blob_url is used to derive the filename for storing the
    Bind & Issue API response in Azure Blob Storage.

    Attributes
    ----------
    job_id : str
        Guidewire Job ID returned from the Quote MCP.

    output_blob_url : str
        Azure Blob URL returned from the Quote MCP.

    Example
    -------
    {
        "job_id": "pc:10234",
        "output_blob_url":
        "https://agenticai1.blob.core.windows.net/guidewire-quote/19F64D19C34B9B1C_Quote_Report_20260715_081238_mail.json"
    }
    """

    job_id: str = Field(
        ...,
        description=(
            "Guidewire Job ID returned from the "
            "guidewire_quote_mcp operation."
        ),
    )

    output_blob_url: str = Field(
        ...,
        description=(
            "Azure Blob URL returned from the guidewire_quote_mcp "
            "operation. This is used to generate the Bind & Issue "
            "output blob filename."
        ),
    )




import logging

from .clients.guidewire_clients import post
from .storage_utils import save_bind_and_issue_output_to_blob

logger = logging.getLogger(__name__)


async def bind_and_issue_policy(
    job_id: str,
    output_blob_url: str,
) -> dict:
    """
    Bind and issue a policy in Guidewire for an existing Job ID.

    This service performs the following steps:

    1. Calls the Guidewire Bind & Issue API.
    2. Uploads the Guidewire response JSON to Azure Blob Storage.
    3. Creates the destination container if it does not already exist.
    4. Returns both the Guidewire response and the newly created
       bind_and_issue_blob_url.

    Guidewire API
    -------------
        POST /job/v1/jobs/{job_id}/bind-and-issue

    Args
    ----
    job_id : str
        The Guidewire Job ID returned from the Quote MCP.

    output_blob_url : str
        The Quote MCP output blob URL. This is used to derive the
        Bind & Issue output filename.

    Example output_blob_url
    -----------------------
    https://agenticai1.blob.core.windows.net/guidewire-quote/
    19F64D19C34B9B1C_Quote_Report_20260715_081238_mail.json

    Returns
    -------
    Success

    {
        "status": True,
        "jobId": "pc:12345",
        "bind_and_issue_blob_url": "...",
        "policyResponse": {...}
    }

    Failure

    {
        "status": False,
        "error": "Failed to bind and issue policy using Guidewire API: ..."
    }
    """

    try:
        logger.info("Calling Guidewire Bind & Issue API for Job ID: %s", job_id)

        policy_resp = post(
            f"/job/v1/jobs/{job_id}/bind-and-issue",
            {},
        )

        logger.info("Guidewire Bind & Issue completed successfully.")

        bind_and_issue_blob_url = (
            await save_bind_and_issue_output_to_blob(
                output_blob_url=output_blob_url,
                bind_and_issue_response=policy_resp,
            )
        )

        logger.info(
            "Bind & Issue response uploaded to Azure Blob Storage."
        )

        return {
            "status": True,
            "jobId": job_id,
            "bind_and_issue_blob_url": bind_and_issue_blob_url,
            "policyResponse": policy_resp,
        }

    except Exception as e:
        logger.exception("Bind & Issue failed.")

        return {
            "status": False,
            "error": f"Failed to bind and issue policy using Guidewire API: {str(e)}",
        }






import json
import logging

from azure.storage.blob.aio import BlobServiceClient

from .service import (
    AZURE_STORAGE_CONNECTION_STRING,
    GUIDEWIRE_BIND_AND_ISSUE_CONTAINER,
    _require_env,
    _parse_blob_url,
    build_bind_and_issue_blob_name,
)

logger = logging.getLogger(__name__)


async def save_bind_and_issue_output_to_blob(
    output_blob_url: str,
    bind_and_issue_response: dict,
) -> str:
    """
    Save the Guidewire Bind & Issue API response to Azure Blob Storage.

    Workflow
    --------
    1. Parse the Quote MCP output_blob_url.
    2. Extract the original blob filename.
    3. Generate a new blob filename by replacing the token immediately
       after the reference id with 'bind_and_issue'.
    4. Upload the response JSON into the
       'guidewire_bind_and_issue' container.
    5. Create the container if it does not already exist.
    6. Return the uploaded blob URL.

    Example
    -------

    Input output_blob_url

    https://agenticai1.blob.core.windows.net/guidewire-quote/
    19F64D19C34B9B1C_Quote_Report_20260715_081238_mail.json


    Stored Blob Name

    19F64D19C34B9B1C_bind_and_issue_Report_20260715_081238_mail.json


    Returned URL

    https://agenticai1.blob.core.windows.net/guidewire_bind_and_issue/
    19F64D19C34B9B1C_bind_and_issue_Report_20260715_081238_mail.json
    """

    _require_env()

    _, original_blob_name = _parse_blob_url(output_blob_url)

    bind_and_issue_blob_name = build_bind_and_issue_blob_name(
        original_blob_name
    )

    json_data = json.dumps(bind_and_issue_response, indent=2)

    async with BlobServiceClient.from_connection_string(
        AZURE_STORAGE_CONNECTION_STRING
    ) as service:

        container_client = service.get_container_client(
            GUIDEWIRE_BIND_AND_ISSUE_CONTAINER
        )

        try:
            await container_client.get_container_properties()
        except Exception:
            logger.info(
                "Container '%s' does not exist. Creating container.",
                GUIDEWIRE_BIND_AND_ISSUE_CONTAINER,
            )
            await container_client.create_container()

        blob_client = container_client.get_blob_client(
            bind_and_issue_blob_name
        )

        await blob_client.upload_blob(
            json_data.encode("utf-8"),
            overwrite=True,
        )

        logger.info(
            "Bind & Issue response uploaded successfully to %s",
            blob_client.url,
        )

        return blob_client.url




import os
from urllib.parse import urlparse, unquote
from dotenv import load_dotenv

load_dotenv()

AZURE_STORAGE_CONNECTION_STRING = os.environ.get(
    "AZURE_STORAGE_CONNECTION_STRING", ""
)

GUIDEWIRE_BIND_AND_ISSUE_CONTAINER = os.environ.get(
    "GUIDEWIRE_BIND_AND_ISSUE_CONTAINER",
    "guidewire_bind_and_issue",
)


def _require_env() -> None:
    """
    Ensure required Azure Storage environment variables exist.
    """
    if not AZURE_STORAGE_CONNECTION_STRING:
        raise RuntimeError(
            "Missing AZURE_STORAGE_CONNECTION_STRING in environment/.env"
        )


def _parse_blob_url(url: str) -> tuple[str, str]:
    """
    Parse an Azure Blob URL and return:

        (container_name, blob_path)

    Example
    -------
    Input:
        https://account.blob.core.windows.net/guidewire-quote/
        19F64D19C34B9B1C_Quote_Report_20260715_081238_mail.json

    Returns:
        (
            "guidewire-quote",
            "19F64D19C34B9B1C_Quote_Report_20260715_081238_mail.json"
        )
    """

    parsed = urlparse(url)

    if not parsed.scheme.startswith("http"):
        raise ValueError("Invalid Azure Blob URL.")

    path = parsed.path.lstrip("/")

    if "/" not in path:
        raise ValueError(
            "Blob URL must contain both container and blob name."
        )

    container, blob_path = path.split("/", 1)

    return unquote(container), unquote(blob_path)


def build_bind_and_issue_blob_name(original_blob_name: str) -> str:
    """
    Build the Bind & Issue blob filename.

    Rule
    ----
    Replace only the token immediately after the reference ID with
    'bind_and_issue'.

    Example
    -------
    Input

        19F64D19C34B9B1C_Quote_Report_20260715_081238_mail.json

    Output

        19F64D19C34B9B1C_bind_and_issue_Report_20260715_081238_mail.json

    Another Example

        19F64D19C34B9B1C_Submission_Report_20260715.json

    Output

        19F64D19C34B9B1C_bind_and_issue_Report_20260715.json
    """

    parts = original_blob_name.split("_", 2)

    if len(parts) < 3:
        raise ValueError(
            "Unexpected blob filename format."
            " Expected REFID_<TYPE>_<remaining_filename>."
        )

    ref_id = parts[0]
    remaining = parts[2]

    return f"{ref_id}_bind_and_issue_{remaining}"


